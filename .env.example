# LLM Provider Configuration
LLM_PROVIDER=openai          # openai | anthropic | azure
OPENAI_API_KEY=your-key-here
ANTHROPIC_API_KEY=your-key-here

# OpenAI Model
OPENAI_MODEL=gpt-4o-mini

# Anthropic Model  
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# v2 Settings
WIKI_SEARCH_TOP_K=3                # number of wiki results to fetch
REACT_MAX_ITERATIONS=5             # max ReAct loop iterations
SCRIPT_BASE_PATH=./resources/scripts  # path to runnable scripts
CONVERSATION_WINDOW_SIZE=10        # messages kept in context window
DEBUG_REACT_STEPS=false            # log ReAct steps to console

# Langfuse Observability (optional — leave empty to disable)
LANGFUSE_SECRET_KEY=               # sk-lf-... from cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=               # pk-lf-... from cloud.langfuse.com
LANGFUSE_BASE_URL=https://cloud.langfuse.com
