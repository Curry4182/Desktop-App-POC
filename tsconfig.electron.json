{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "lib": ["ES2020"],
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["electron/**/*", "shared/**/*"]
}
