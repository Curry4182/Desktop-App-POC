{
  "name": "design-assistant",
  "version": "0.1.0",
  "description": "CAD Design Assistant v2 — Multi-Agent with Supervisor + ReAct",
  "main": "electron/main.ts",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS='--import tsx' concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && electron-builder",
    "test": "vitest run --config vitest.config.ts",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json && tsc --project tsconfig.node.json --noEmit && tsc --project tsconfig.electron.json --noEmit",
    "eval:langfuse:cad-catia": "node --import tsx scripts/langfuse/run-cad-catia-eval.ts",
    "eval:langfuse:cad-catia:compare": "node --import tsx scripts/langfuse/run-cad-catia-eval.ts --compare"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.0.0",
    "@langchain/core": "^1.0.0",
    "@langchain/langgraph": "^1.0.0",
    "@langchain/openai": "^1.0.0",
    "@langfuse/client": "^5.0.1",
    "@langfuse/langchain": "^5.0.1",
    "dotenv": "^16.4.0",
    "langchain": "^1.0.0",
    "pinia": "^2.2.0",
    "systeminformation": "^5.31.1",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vitest": "^2.0.0",
    "vue-tsc": "^2.0.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.design-assistant.app",
    "productName": "Design Assistant",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "agent/**/*",
      "resources/**/*",
      ".env"
    ],
    "extraResources": [
      {
        "from": "resources/scripts",
        "to": "scripts",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
